{
  "mcpServers": {
    "material-management": {
      "command": "python",
      "args": [
        "/home/julei/backend/mcp-server/mcp_server.py",
        "--config",
        "/home/julei/backend/mcp-server/config.yaml"
      ],
      "env": {
        "BACKEND_URL": "http://localhost:8088",
        "JWT_SECRET": "your-secret-key",
        "BACKEND_USERNAME": "admin",
        "BACKEND_PASSWORD": "admin"
      }
    }
  }
}
